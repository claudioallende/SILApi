<?xml version="1.0" encoding="utf-8" ?>
<hibernate-mapping xmlns="urn:nhibernate-mapping-2.2" auto-import="true" assembly="ResourceServer" namespace="ResourceServer.Models">
  <class name="CuposCuit" table="Cuposcuit">
    <cache usage="read-write"/>  
    <composite-id>
        <key-property name="Cuit" column="Cuit"/>
        <key-property name="Nombre" column="Nombre"/>
     </composite-id>
    <property name="Domicilio">
      <column name="Domicilio"/>
    </property>
    <property name="Localidad">
      <column name="Localidad"/>
    </property>
    <property name="Provincia">
      <column name="Provincia"/>
    </property>
    <property name="Cuenta" />
  </class>
</hibernate-mapping>