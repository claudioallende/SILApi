<?xml version="1.0" encoding="utf-8" ?>
<hibernate-mapping xmlns="urn:nhibernate-mapping-2.2"
                   auto-import="true"
                   assembly="ResourceServer"
                   namespace="ResourceServer.Models">
	<class name="CondicionGrano" table="CONDICIONGRANO">
		<cache usage="read-write"/>
		<id name="Id">
			<column name="ID"/>
			<generator class="sequence-identity">
				<param name="sequence">CONDICIONGRANO_SEQ</param>
			</generator>
		</id>
		<property name="Nombre">
			<column name="NOMBRE"/>
		</property>
	</class>
</hibernate-mapping>
